 <script is:inline>
  const items = document.querySelectorAll(".faq-item");
  const btn = document.getElementById("viewMoreBtn");

  const initialVisible = 5;
  const increment = 5;

  let visible = initialVisible;
  let expanded = false;

  btn?.addEventListener("click", () => {
    if (!expanded) {
      // Show 5 more FAQs
      const next = visible + increment;

      for (let i = visible; i < next && i < items.length; i++) {
        items[i].classList.remove("hidden");
      }

      visible = next;

      // If all FAQs are visible, change button to "View Less"
      if (visible >= items.length) {
        expanded = true;
        btn.textContent = "View Less";
      }
    } else {
      // Hide all except the first 5 FAQs
      for (let i = initialVisible; i < items.length; i++) {
        items[i].classList.add("hidden");

        // Close any open FAQ
        items[i].removeAttribute("open");
      }

      visible = initialVisible;
      expanded = false;
      btn.textContent = "View More";

      // Scroll back to the FAQ section
      document
        .getElementById("faq")
        ?.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  });
</script> 
</section>  
---
import { Image } from "astro:assets";

// Import Disaster Illustrations
import flood from "../assets/Images/flood.png";
import landslide from "../assets/Images/landslide.png";
import earthquake from "../assets/Images/earthquake.png";
import cyclone from "../assets/Images/cyclone.png";
import fire from "../assets/Images/fire.png";

// Import Disaster Outline Icons
import floodIcon from "../assets/Images/icon4a.png";
import landslideIcon from "../assets/Images/icon5a.png";
import earthquakeIcon from "../assets/Images/icon7a.png";
import cycloneIcon from "../assets/Images/icon6a.png";
import fireIcon from "../assets/Images/icon8a.png";

const themes = [
  {
    title: "FLOODS",
    image: flood,
    icon: floodIcon,
  },
  {
    title: "LANDSLIDES",
    image: landslide,
    icon: landslideIcon,
  },
  {
    title: "EARTHQUAKES",
    image: earthquake,
    icon: earthquakeIcon,
  },
  {
    title: "CYCLONES",
    image: cyclone,
    icon: cycloneIcon,
  },
  {
    title: "FIRE",
    image: fire,
    icon: fireIcon,
  },
];
---

<section id="themes" class="bg-white py-20">
  <div class="mx-auto max-w-7xl px-6">

    <h2 class="mb-8 text-center text-3xl font-bold uppercase text-blue-700">
      Theme
    </h2>

    <div class="rounded-3xl border border-slate-100 bg-white p-8 shadow-md">

      <div class="grid items-center gap-10 lg:grid-cols-[320px_1fr]">

        <!-- Left Side -->
        <div>

          <h2 class="text-2xl font-extrabold uppercase leading-tight text-[#0B2F83]">
            Disaster Detection
            <br />
            & Early Warnings
          </h2>

          <p class="mt-6 leading-8 text-gray-600">
            Design and develop Open Source Hardware solutions that detect,
            monitor and provide early warnings for natural disasters, helping
            communities respond faster and build a safer, more resilient future.
          </p>

          <button
            class="mt-8 rounded-xl bg-gradient-to-r from-blue-700 to-green-600 px-8 py-4 font-semibold text-white transition hover:scale-105"
          >
            Learn More →
          </button>

        </div>

        <!-- Right Side -->
        <div class="grid grid-cols-5 justify-items-center gap-4">

          {themes.map((item) => (

            <div class="w-[145px] text-center">

<div class="relative w-[140px] mx-auto">
  <Image
    src={item.image}
    alt={item.title}
    class="w-full h-[270px] rounded-2xl object-cover"
  />

  <div
    class="absolute left-1/2 -bottom-7 -translate-x-1/2 w-16 h-16 rounded-full bg-[#5C2D91] flex items-center justify-center shadow-xl"
  >
    <Image
      src={item.icon}
      alt={item.title}
      class="w-9 h-9 object-contain"
    />
  </div>
</div>
              <h3 class="mt-10 text-lg font-bold uppercase text-[#412080]">
                {item.title}
              </h3>

            </div>

          ))}

        </div>

      </div>

    </div>

  </div>
</section>
---
import { CalendarDays, ClipboardCheck, FileText } from "lucide-astro";
import { Image } from "astro:assets";
import Trophy from "../assets/Images/icon3.png";

const timeline = [
  {
    Icon: CalendarDays,
    image: null,
    color: "#1E7A35",
    date: "15TH AUG 2026",
    title: "Registrations Open",
  },
  {
    Icon: ClipboardCheck,
    image: null,
    color: "#1E40AF",
    date: "15TH SEPT 2026",
    title: "Midway Review",
  },
  {
    Icon: FileText,
    image: null,
    color: "#6B21A8",
    date: "30TH SEPT 2026",
    title: "Final Submission",
  },
  {
    Icon: null,
    image: Trophy,
    color: "#F97316",
    date: "25TH OCT 2026",
    title: "Results & Awards",
  },
];
---

<section id="timeline" class="py-16 bg-white scroll-mt-18">
  <div class="max-w-7xl mx-auto px-6">

    <h2 class="mb-8 text-center text-3xl font-bold uppercase text-blue-700">
      Timeline
    </h2>

    <div class="mx-auto max-w-6xl rounded-3xl border border-gray-100 bg-white px-8 py-10 shadow-sm">

      <div class="relative">

        <!-- Dashed Line -->
        <div class="absolute left-0 right-0 top-10 border-t-2 border-dashed border-gray-300"></div>

        <div class="relative z-10 grid grid-cols-4 gap-6">

          {timeline.map((item) => (
            <div class="flex flex-col items-center text-center">

              <div
                class="flex h-20 w-20 items-center justify-center rounded-full border-[3px] bg-white"
                style={`border-color:${item.color}; color:${item.color};`}
              >
                {
                  item.Icon ? (
                    <item.Icon size={36} />
                  ) : (
                    <Image
                      src={item.image}
                      alt={item.title}
                      class="h-9 w-9 object-contain"
                    />
                  )
                }
              </div>

              <h3
                class="mt-5 text-xl font-extrabold uppercase"
                style={`color:${item.color};`}
              >
                {item.date}
              </h3>

              <p class="mt-2 text-lg text-gray-700">
                {item.title}
              </p>

            </div>
          ))}

        </div>

      </div>

    </div>

  </div>
</section>
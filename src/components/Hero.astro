---
import { Image } from 'astro:assets';
import rhImg from '../assets/Images/hero.png';
import title from '../assets/Images/lhImg.png';
---

<section class="relative w-full pt-6 pb-12 overflow-hidden">
  
  <div class="w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col lg:flex-row items-center justify-between">
    
    <!-- Left Column: Title Section -->
    <div class="w-full lg:w-1/2 flex flex-col space-y-6 z-10">
      
      <!-- Top Small Brand Text -->
      <div class="space-y-1">
        <h4 class="text-brand-orange dark:text-brand-orange font-extrabold text-base sm:text-lg tracking-wide uppercase text-center lg:text-left">
        </h4>
      </div>

      <!-- Title Banner (lhImg.png) -->
      <div class="w-full max-w-lg mx-auto lg:mx-0">
        <Image 
          src={title} 
          alt="National Make-A-Thon Banner Title" 
          class="w-full h-auto object-contain drop-shadow-sm"
        />
      </div> 

      <!-- Timeline & Status Panel -->
      <div class="flex items-start space-x-4 bg-card-bg/60 dark:bg-card-bg/30 p-4 rounded-3xl border border-border-subtle max-w-md mx-auto lg:mx-0 shadow-xs">
        <div class="text-brand-blue flex-shrink-0 mt-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <div class="space-y-1">
          <p class="text-xl sm:text-2xl font-black text-[#0B2F83] tracking-tight border-b-3 dark:text-[#0B2F83] pb-1 inline-block">
            1st August - 30 September
          </p>
          <p class="text-sm sm:text-base font-extrabold text-red-500 uppercase tracking-widest pt-1">
            Registration Started
          </p>
        </div>
      </div>

      <!-- Action Buttons Row (Centered under the Left Title Block) -->
      <div class="flex flex-row items-center justify-center max-w-lg mx-auto lg:mx-0 gap-4 pt-2">
        <a 
          href="#" 
          class="px-8 py-3.5 bg-gradient-to-r from-[#0c4384] to-[#047235] text-white font-bold text-base rounded-lg shadow-md hover:brightness-110 active:scale-95 transition-all text-center min-w-[160px]"
        >
          Register Now
        </a>
        
        <a 
          href="#about" 
          class="px-8 py-3.5 border-2 border-[#0c4384] dark:border-sky-400 text-[#0c4384] dark:text-sky-400 font-bold text-base rounded-lg bg-transparent hover:bg-[#0c4384]/5 dark:hover:bg-sky-400/5 active:scale-95 transition-all text-center min-w-[160px]"
        >
          Know more...
        </a>
      </div>

    </div>

    <!-- Right Column: Hero Graphic (Full width on right, overlapping left title section) -->
    <div class="w-full lg:w-1/2 flex justify-center lg:justify-start lg:-ml-16 z-0 mt-8 lg:mt-0">
      <Image 
        src={rhImg} 
        alt="Open Source Hardware Storm Alert Developers" 
        class="w-full h-auto object-contain select-none pointer-events-none drop-shadow-xl"
        priority
      />
    </div>

  </div>
  
</section>
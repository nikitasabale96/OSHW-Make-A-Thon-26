---
import { Image } from "astro:assets";
import IIT from "../assets/Images/logo_1.png";
import FOSSEE from "../assets/Images/logo_2.png";
import OSHW from "../assets/Images/logo_3.png";
---

<header class="sticky top-0 z-50 w-full border-b border-gray-100 bg-white shadow-sm">
  <div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">

    <!-- Logos -->
    <div class="flex items-center gap-2 sm:gap-4">
      <Image
        src={IIT}
        alt="IIT Bombay"
        class="h-10 sm:h-12 lg:h-14 w-auto object-contain"
      />

      <div class="hidden sm:block h-8 w-px bg-gray-300"></div>

      <Image
        src={FOSSEE}
        alt="FOSSEE"
        class="h-10 sm:h-12 lg:h-14 w-auto object-contain"
      />

      <div class="hidden sm:block h-8 w-px bg-gray-300"></div>

      <Image
        src={OSHW}
        alt="Open Hardware"
        class="h-10 sm:h-12 lg:h-14 w-auto object-contain"
      />
    </div>

    <!-- Desktop Navigation -->
    <nav class="hidden lg:flex items-center space-x-8 text-lg font-medium text-gray-700">
      <a href="#" class="border-b-2 border-blue-600 pb-1 text-blue-600">Home</a>
      <a href="/#about" class="hover:text-blue-600">About</a>
      <a href="/#themes" class="hover:text-blue-600">Theme</a>
      <a href="/#timeline" class="hover:text-blue-600">Timeline</a>
      <a href="/#resources" class="hover:text-blue-600">Resources</a>
      <a href="/#rules" class="hover:text-blue-600">Rules</a>
      <a href="/#faq" class="hover:text-blue-600">FAQ</a>
      <a href="/#contact" class="hover:text-blue-600">Contact</a>
    </nav>

    <!-- Mobile Menu Button -->
    <button
      id="menu-btn"
      class="flex lg:hidden items-center justify-center rounded-md p-2 text-gray-700"
      aria-label="Toggle menu"
    >
      <svg
        class="h-7 w-7"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M4 6h16M4 12h16M4 18h16"
        />
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="hidden border-t border-gray-200 bg-white lg:hidden"
  >
    <nav class="flex flex-col px-6 py-4 text-base font-medium text-gray-700">
      <a href="#" class="py-2 hover:text-blue-600">Home</a>
      <a href="/#about" class="py-2 hover:text-blue-600">About</a>
      <a href="/#themes" class="py-2 hover:text-blue-600">Theme</a>
      <a href="/#timeline" class="py-2 hover:text-blue-600">Timeline</a>
      <a href="/#resources" class="py-2 hover:text-blue-600">Resources</a>
      <a href="/#rules" class="py-2 hover:text-blue-600">Rules</a>
      <a href="/#faq" class="py-2 hover:text-blue-600">FAQ</a>
      <a href="/#contact" class="py-2 hover:text-blue-600">Contact</a>
    </nav>
  </div>
</header>

<script>
  const button = document.getElementById("menu-btn");
  const menu = document.getElementById("mobile-menu");

  button?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });
</script>
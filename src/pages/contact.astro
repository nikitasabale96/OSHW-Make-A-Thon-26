---
// import SectionTitle from "./.astro";
---

<section id="contact" class="py-12 scroll-mt-18 scroll-pt-18">
  <div class="max-w-6xl mx-auto px-6">
        <h2 class="mb-2  text-center text-2xl sm:text-2xl lg:text-3xl font-bold uppercase  text-blue-700">
Contact Us
    </h2>
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm text-center">
      <p class="text-lg md:text-md text-black">
        Please write to us in case of any queries regarding the FOSSEE OSHW Make-A-Thon at:
       
      </p>
      <p class="mt-2 text-lg md:text-md text-black">
        <span class="font-semibold text-black"> Email:</span> <a
          href="mailto:contact-oshw@fossee.in"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sky-600 text-lg hover:text-sky-700 underline"
        >
          contact-oshw@fossee.in
        </a>
      </p>
    </div>
  </div>
</section>
